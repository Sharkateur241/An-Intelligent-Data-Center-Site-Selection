# Data Center Intelligent Site Selection & Energy Optimization - Env sample
# Copy this file to .env and fill in your settings

# ===================
# API configuration
# ===================
# OpenAI API key (required)
OPENAI_API_KEY=your_openai_api_key_here

# API base URL (optional, defaults to GPTPlus5)
OPENAI_BASE_URL=https://api.gptplus5.com/v1

# ===================
# Proxy configuration
# ===================
# HTTP proxy (if needed)
HTTP_PROXY=http://127.0.0.1:1082
HTTPS_PROXY=http://127.0.0.1:1082
http_proxy=http://127.0.0.1:1082
https_proxy=http://127.0.0.1:1082

# ===================
# GEE configuration
# ===================
# Google Earth Engine project ID
GEE_PROJECT_ID=your_gee_project_id

# GEE service account key path
GEE_SERVICE_ACCOUNT_KEY_PATH=./gee_service_account_key.json

# ===================
# Server configuration
# ===================
# Backend service port
BACKEND_PORT=8000

# Frontend service port
FRONTEND_PORT=3000

# ===================
# Other settings
# ===================
# Debug mode
DEBUG=false

# Log level
LOG_LEVEL=INFO
