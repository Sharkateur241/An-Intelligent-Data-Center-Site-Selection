# 数据中心智能选址与能源优化系统 - 环境配置示例
# 复制此文件为 .env 并填入您的配置

# ===================
# API 配置
# ===================
# OpenAI API 密钥 (必填)
OPENAI_API_KEY=your_openai_api_key_here

# API 基础URL (可选，默认使用GPTPlus5)
OPENAI_BASE_URL=https://api.gptplus5.com/v1

# ===================
# 代理配置
# ===================
# HTTP 代理 (如果在中国大陆使用)
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
http_proxy=http://127.0.0.1:7897
https_proxy=http://127.0.0.1:7897

# ===================
# GEE 配置
# ===================
# Google Earth Engine 项目ID
GEE_PROJECT_ID=your_gee_project_id

# GEE 服务账号密钥文件路径
GEE_SERVICE_ACCOUNT_KEY_PATH=./gee_service_account_key.json

# ===================
# 服务器配置
# ===================
# 后端服务端口
BACKEND_PORT=8000

# 前端服务端口
FRONTEND_PORT=3000

# ===================
# 其他配置
# ===================
# 调试模式
DEBUG=false

# 日志级别
LOG_LEVEL=INFO
