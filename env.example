# Data Center Intelligent Site Selection & Energy Optimization - Env sample
# Copy this file to .env and fill in your settings

# ===================
# API configuration
# ===================
# OpenAI API key (required)
OPENAI_API_KEY=your_openai_api_key_here

# API base URL (optional — defaults to official OpenAI endpoint)
OPENAI_BASE_URL=https://api.openai.com/v1

# ===================
# CORS configuration
# ===================
# Comma-separated list of allowed frontend origins (required in production)
CORS_ALLOW_ORIGINS=http://localhost:3000

# ===================
# Proxy configuration
# ===================
# HTTP/HTTPS proxy — leave blank if no proxy is needed
# (HTTP_PROXY and HTTPS_PROXY are no longer set by default)
HTTP_PROXY=
HTTPS_PROXY=

# ===================
# SSL (advanced)
# ===================
# Set to true ONLY in dev environments where Python's cert store is missing/broken
# (common on macOS with python.org installer — run Install Certificates.command instead)
GEE_DISABLE_SSL_VERIFY=false
DISABLE_SSL_VERIFY=false

# ===================
# GEE configuration
# ===================
# Google Earth Engine project ID
GEE_PROJECT_ID=your_gee_project_id

# GEE service account key path
GEE_SERVICE_ACCOUNT_KEY_PATH=./gee_service_account_key.json

# ===================
# Real data API settings (all free, no key required)
# ===================

# NASA POWER Solar Irradiance API — no key required
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/climatology/point

# Open-Meteo (retained for future use — currently wind+climate use NASA POWER)
OPEN_METEO_CLIMATE_URL=https://climate-api.open-meteo.com/v1/climate
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive

# Open-Elevation (SRTM) — no key required
OPEN_ELEVATION_URL=https://api.open-elevation.com/api/v1/lookup

# OpenStreetMap Overpass API — no key required
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# USGS Seismic Hazard — no key required
USGS_HAZARD_URL=https://earthquake.usgs.gov/ws/designmaps/nehrp-2020.json

# ===================
# PROMETHEE II tuning
# ===================
PROMETHEE_SIGMA=0.2
PROMETHEE_WEIGHT_SOLAR=0.20
PROMETHEE_WEIGHT_WIND=0.15
PROMETHEE_WEIGHT_GRID=0.20
PROMETHEE_WEIGHT_LAND=0.15
PROMETHEE_WEIGHT_HAZARD=0.15
PROMETHEE_WEIGHT_TEMP=0.075
PROMETHEE_WEIGHT_WATER=0.075

# ===================
# Server configuration
# ===================
# Backend service port
BACKEND_PORT=8000

# Frontend service port
FRONTEND_PORT=3000

# ===================
# Other settings
# ===================
# Debug mode
DEBUG=false

# Log level
LOG_LEVEL=INFO
